# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=customer_service_kb

# App Settings
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# Escalation Settings
ESCALATION_SENTIMENT_THRESHOLD=-0.5
ESCALATION_REPEAT_THRESHOLD=3
